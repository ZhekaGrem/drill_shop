# ====================
# 🌍 СЕРЕДОВИЩЕ
# ====================
NODE_ENV="development"

# ====================
# 🔗 BACKEND API
# ====================
# Для локального розробки: http://localhost:3001/api/v1
# Для продакшену: https://your-backend.railway.app/api/v1
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ====================
# 🔐 SUPABASE (Аутентифікація)
# ====================
# Отримати на: https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ====================
# 🖼️ CLOUDINARY (Зображення)
# ====================
# Отримати на: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_API_IMG_URL="https://res.cloudinary.com/your-cloud-name"

# ====================
# 💬 TELEGRAM BOT (Сповіщення про замовлення)
# ====================
# Створити бота: https://t.me/BotFather
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"
TELEGRAM_CHAT_ID="-1001234567890"