# ====================
# 🌍 СЕРЕДОВИЩЕ
# ====================
NODE_ENV="development"

# ====================
# 🔗 BACKEND API
# ====================
# URL бекенду (локально або продакшен)
# Локально: http://localhost:3001/api/v1
# Продакшен: https://your-backend.railway.app/api/v1
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ====================
# 🔐 SUPABASE (Аутентифікація)
# ====================
# URL та ключі з вашого Supabase проекту
# Отримати: https://supabase.com → Settings → API
# ВАЖЛИВО: Використовуйте anon key (публічний), НЕ service_role key!
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ====================
# 🖼️ CLOUDINARY (Зображення)
# ====================
# Cloud name з вашого Cloudinary акаунту
# Отримати: https://cloudinary.com → Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# URL для отримання зображень через API (необов'язково, формується автоматично)
NEXT_PUBLIC_API_IMG_URL="http://localhost:3001"

# ====================
# 💬 TELEGRAM BOT (Форма зворотного зв'язку)
# ====================
# Використовується для надсилання повідомлень з форми контактів на сайті
# Це той самий admin бот що і в backend (для сповіщень адмінів)
# Створити бота: https://t.me/BotFather
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"
TELEGRAM_CHAT_ID="-1001234567890"
